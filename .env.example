# ── Variáveis de ambiente da app FO.CU (packages/web) ──
# Copia para .env e preenche. NÃO faças commit do .env (já está no .gitignore).

# Porta (local). No Railway é automática.
PORT=3000

# URL público da app. Local: http://localhost:3000 | Produção: domínio do Railway
WEBSITE_URL=http://localhost:3000

# Email que fica admin automaticamente
ADMIN_EMAIL=thebodylaab@gmail.com

# Segredo de autenticação (better-auth) — aleatório e FIXO.
# Gera com: bun -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
BETTER_AUTH_SECRET=

# Base de dados Turso/LibSQL
DATABASE_URL=libsql://o-teu-banco.turso.io
DATABASE_AUTH_TOKEN=

# Chave Anthropic (geração de receitas por IA)
ANTHROPIC_API_KEY=

# Stripe (só se usares pagamentos/subscrições)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
